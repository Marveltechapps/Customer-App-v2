# Local backend: match PORT in selorg-backend (default 3333). On a physical device / Expo Go, use your PC LAN IP — not localhost.
# Example: API_BASE_URL=http://192.168.1.41:3333/api/v1/customer
ENV=development
API_BASE_URL=http://localhost:3333/api/v1/customer

# EAS Project ID for Expo push notifications. Run: eas login && eas init
# Required for: order status push notifications on physical devices
EAS_PROJECT_ID=

# Google Maps API key (Maps SDK for Android/iOS, Directions API, Geocoding). Get from Google Cloud Console.
# Required for: RouteMap, MapAddressPin, order tracking. Run `expo prebuild --clean` after setting.
GOOGLE_MAPS_API_KEY=AIza...
API_VERSION=/api/v1
